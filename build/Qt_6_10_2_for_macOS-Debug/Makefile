####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/Campus/bin || mkdir -p $(INSTALL_ROOT)/opt/Campus/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/Campus/bin/Campus.app
	
	$(QINSTALL) Campus.app $(INSTALL_ROOT)/opt/Campus/bin/Campus.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/Campus/bin/Campus.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/Campus/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

